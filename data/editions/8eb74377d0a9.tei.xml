   <tei:text>
      <tei:body>
         <tei:pb facs="#surf-IMG_DEFAULT_5618318" n="1"/>
         <tei:p>
         <tei:lb/>Viele herzliche Grüße sendet Ihnen G.P.
         <tei:lb/>Ich fahre heute nach Hamburg, von da nach Bremen
         <tei:lb/>und <tei:gap reason="illegible" quantity="1" unit="words"/> längerem Aufenthalt nach
         <tei:lb/>Scheveningen <tei:gap reason="illegible" quantity="1" unit="words"/> Hotel Garin, wohin ich
         <tei:lb/>bitte, mir zu schreiben, wie Ihnen Paris gefallen hat.
      </tei:p>
         <tei:pb facs="#surf-IMG_DEFAULT_5618319" n="2"/>
         <tei:address>
         <tei:addrLine><tei:sic>Wolgeboren</tei:sic></tei:addrLine>

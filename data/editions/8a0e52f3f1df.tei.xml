   <tei:text>
      <tei:body>
         <tei:pb facs="#surf-IMG_DEFAULT_5387506" n="1"/>
                        <tei:opener>
         <tei:dateline>
            <tei:placeName>Wien</tei:placeName>,
            <tei:date when="1894-07-01">1.7.94</tei:date>
         </tei:dateline>
         <tei:salute>Hochgeehrter Herr Krauss!</tei:salute>
      </tei:opener>

      <tei:p>
         <tei:lb/>Wir sitzen uns allabendlich
         <tei:lb/>beim elektrischen Schein u.
         <tei:lb/>italienischem Klang gegenüber.
         <tei:lb/>Ja wohl <tei:gap reason="illegible" quantity="11" unit="words"/>
         <tei:lb/>liebenswürdiger<tei:lb break="no"/>Weise annahmen Neumann
         <tei:lb/>Hofer gegenüber. Ich füge ab<tei:lb break="no"/>sichtlich nicht „Herr" vor.
         <tei:lb/>Vor Glück geschieht es nicht
         <tei:lb/>aus Freunschaft u. vor letzterem
         <tei:lb/>nicht Feindschaft, ich
      </tei:p>
         <tei:pb facs="#surf-IMG_DEFAULT_5387507" n="2"/>
          <tei:p>
         <tei:lb/>hasse und verachte ihn!
         <tei:lb/>Kann ich nicht das Ver<tei:lb break="no"/>gnügen haben Sie vor Ihrer
         <tei:lb/>Abreise nach Ischl auf
         <tei:lb/>einen Moment nur noch
         <tei:lb/>zu sprechen?
         <tei:lb/>Ja, wann u. wo lassen Sie
         <tei:lb/>mich durch Überbringer rufen
         <tei:lb/>Bitte! bitte! -
         <tei:lb/>Es grüßt unbekannterweise
         <tei:lb/>doch auf's Wärmeste
         <tei:lb/>und Dankbarste
      </tei:p>
            <tei:closer>
         <tei:signed>M. Seliger</tei:signed>
         <tei:address>
            <tei:addrLine>Alserstr. 8 I</tei:addrLine>
            <tei:addrLine>Thür 6</tei:addrLine>
         </tei:address>
      </tei:closer>
      </tei:body>

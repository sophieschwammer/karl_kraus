   <tei:text>
      <tei:body>
         <tei:div type="letter">
         <tei:pb facs="#surf-IMG_DEFAULT_5618260" n="1"/>
         
         <tei:opener>
               <tei:salute>Lieber Herr Kraus!</tei:salute>
            </tei:opener>
<tei:p>
      <tei:lb/>Ich erinnere mich
        <tei:lb/>daß Sie mich
        <tei:lb/>in Ischl ganz
        <tei:lb/>gut leiden kon<tei:lb break="no"/>nten? Nun möchte
        <tei:lb/>ich Sie ersuchen
        <tei:lb/>wenn es Ihre Zeit
        <tei:lb/>erlaubt mir eine
        <tei:lb/>Stunde zu widmen
        <tei:lb/>ich möchte mich
        <tei:lb/>so gerne wieder
         </tei:p>
         <tei:pb facs="#surf-IMG_DEFAULT_5618261" n="2"/>
         <tei:p>
         <tei:lb/>einmal mit
        <tei:lb/>einem vernünftigen
        <tei:lb/>Menschen den
        <tei:lb/>ich gut leiden
        <tei:lb/>kann <tei:gap reason="illegible" quantity="1" unit="words"/>
        <tei:lb/>bitte wenn Sie
        <tei:lb/>Zeit haben, besuchen
        <tei:lb/>Sie mich im
        <tei:lb/>Laufe dieser
        <tei:lb/>Woche einmal!
        <tei:lb/>Benachrichtigen
        <tei:lb/>Sie mich aber vor<tei:lb break="no"/>her damit ich
        <tei:lb/>zu Hause bin!
      </tei:p>
         <tei:closer>
        <tei:salute>Mit besten Grüßen</tei:salute>
        <tei:signed>
          <tei:persName>
            <tei:unclear reason="illegible">Fanny</tei:unclear>
            <tei:gap reason="illegible" quantity="2" unit="words"/>
          </tei:persName>
        </tei:signed>
        <tei:address>
          <tei:addrLine>II. Czerningasse 15. I/15</tei:addrLine>
        </tei:address>
      </tei:closer>


   <tei:text>
      <tei:body>
         <tei:pb facs="#surf-IMG_DEFAULT_5618315" n="1"/>
         
      <tei:opener>
         <tei:salute>Lieber Freund!</tei:salute>
      </tei:opener>

      <tei:p>
         <tei:lb/>Bitte sind Sie nicht sehr
         <tei:lb/>böse auf mich - ich konnte
         <tei:lb/>wirklich nicht auf Sie war<tei:lb break="no"/>ten. Sie sind auch nicht
         <tei:lb/>um 3 Uhr gekommen-
         <tei:lb/>wären Sie pünktlich bei
         <tei:lb/>mir gewesen - hätten Sie
         <tei:lb/>mich noch getroffen. Jetzt
         <tei:lb/>verreise ich auf einige
         <tei:lb/>Tage weg - erwarte Sie
         <tei:lb/>aber bestimmt müssen <tei:gap reason="illegible" quantity="1" unit="words"/>
         <tei:lb/><tei:gap reason="illegible" quantity="5" unit="words"/>
      </tei:p>
         <tei:pb facs="#surf-IMG_DEFAULT_5618316" n="2"/>
         <tei:p>
         <tei:lb/>bin ich Montag - Mittwoch
         <tei:lb/>Freitag zu treffen - schreiben
         <tei:lb/>Sie mir also wann Sie
         <tei:lb/>kommen. Ich habe viel mit
         <tei:lb/>Ihnen zu sprechen und
         <tei:lb/>mehr zu sorgen.
      </tei:p>

      <tei:closer>
         <tei:salute>Herzlichst</tei:salute>
         <tei:signed>
            <tei:unclear reason="illegible">Metting</tei:unclear>
         </tei:signed>
      </tei:closer>
      </tei:body>
   </tei:text>
